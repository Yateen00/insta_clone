<h2 class="text-xl font-bold mb-4 text-white">Follow Requests</h2>

<% if @follow_requests.any? %>
  <ul id="follow_requests_list" class="space-y-2">
    <% @follow_requests.each do |follow| %>
      <%= render "follows/follow_request_item", follow: follow %>
    <% end %>
  </ul>
<% else %>
  <p class="text-gray-500">No pending follow requests.</p>
<% end %>
